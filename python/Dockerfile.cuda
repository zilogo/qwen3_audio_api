FROM nvidia/cuda:12.8.1-devel-ubuntu24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        git \
        ninja-build \
        python3.12 \
        python3.12-dev \
        python3.12-venv \
        ffmpeg \
        libsndfile1 \
        sox \
    && rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

WORKDIR /app

ENV UV_PYTHON=python3.12 \
    CUDA_HOME=/usr/local/cuda \
    PATH="/usr/local/cuda/bin:${PATH}" \
    LD_LIBRARY_PATH="/usr/local/cuda/lib64:${LD_LIBRARY_PATH}" \
    TORCH_CUDA_ARCH_LIST="12.0" \
    FLASH_ATTN_CUDA_ARCHS="120" \
    FLASH_ATTENTION_SKIP_CUDA_BUILD=FALSE \
    FLASH_ATTENTION_FORCE_BUILD=TRUE \
    MAX_JOBS=4 \
    NVCC_THREADS=2

COPY pyproject.toml uv.lock ./

# Install the locked dependency graph first.
RUN uv sync --frozen --no-dev

# Ensure the venv has pip, then replace locked CPU torch packages with CUDA 12.8 wheels.
ENV VIRTUAL_ENV=/app/.venv \
    PATH="/app/.venv/bin:$PATH"
RUN python -m ensurepip --upgrade && \
    uv pip uninstall torch torchaudio && \
    uv pip install --no-cache-dir --index-url https://download.pytorch.org/whl/cu128 torch torchaudio && \
    python - <<'PY2'
import torch
print('torch', torch.__version__)
print('cuda', torch.version.cuda)
print('cuda_available', torch.cuda.is_available())
PY2

# Install flash-attn against the CUDA-enabled torch toolchain and only build the Blackwell target.
RUN uv pip install --no-cache-dir flash-attn --no-build-isolation && \
    python - <<'PY3'
import flash_attn
print('flash_attn', flash_attn.__file__)
PY3

COPY main.py .

ENV QWEN_TTS_DEVICE=cuda:0 \
    QWEN_TTS_DTYPE=bfloat16 \
    QWEN_TTS_ATTN=flash_attention_2 \
    HOST=0.0.0.0 \
    PORT=8000 \
    NVIDIA_VISIBLE_DEVICES=all \
    NVIDIA_DRIVER_CAPABILITIES=compute,utility \
    PYTHONWARNINGS="ignore::SyntaxWarning"

EXPOSE 8000

CMD ["/app/.venv/bin/python", "main.py"]
